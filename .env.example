# Flask configuration
FLASK_APP=app.py
FLASK_DEBUG=True
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# FitWiki Core library path (uses lib/fitwiki submodule by default)
# FITWIKI_CORE_PATH=/path/to/fitwiki

# FitWiki scraper configurations (falls back to fitwiki/.env if not present here)
# FITWIKI_COOKIES="DokuWiki=..."
# FITWIKI_BASE_URL="https://fit-wiki.cz"
# FITWIKI_DELAY=1.0
